# ─────────────────────────────────────────────────────────────
# annakkyeo (안낚여) 환경 변수 예시
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값을 채워 넣으세요.
#   (Windows CMD)  copy .env.example .env
#   (bash)         cp .env.example .env
# .env 는 .gitignore 에 포함되어 커밋되지 않습니다. 실제 키를 이 파일(.env.example)에는
# 절대 적지 마세요 — .env.example 은 저장소에 공개됩니다.
# ─────────────────────────────────────────────────────────────

# ── Hugging Face ─────────────────────────────────────────────
# 용도: gated 모델(Llama 3.2 등) 다운로드 + 어댑터/데이터셋 push
# 발급: https://huggingface.co/settings/tokens (Fine-grained)
#   권한: gated repos read + personal namespace read/write
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 모델/데이터셋을 올릴 기본 네임스페이스(HF 사용자명 또는 조직명)
HF_HOME_NAMESPACE=your-hf-username

# ── OpenAI ───────────────────────────────────────────────────
# 용도: GPT 베이스라인 비교 + LLM-judge(설명 품질 평가) + 증강/라벨 프로토타입
# 발급: https://platform.openai.com/api-keys
#   ※ 예산 상한 설정 권장 ($10~20)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 베이스라인/judge 에 사용할 모델 (필요 시 변경)
OPENAI_BASELINE_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o

# ── Weights & Biases (실험 추적) ─────────────────────────────
# 용도: 학습 로그/지표 추적. 발급: https://wandb.ai/authorize
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=annakkyeo
WANDB_ENTITY=your-wandb-entity
# 오프라인/폐쇄망에서 학습 시 "offline", 평상시 "online"
WANDB_MODE=online

# ── 경로 (선택 — 기본값이 있으면 비워둬도 됨) ────────────────
# 대용량 모델/데이터 캐시 위치 (드라이브 용량 관리용)
HF_CACHE_DIR=./.cache/huggingface
DATA_DIR=./data
OUTPUT_DIR=./outputs
